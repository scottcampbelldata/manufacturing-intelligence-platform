# Backend (FastAPI) environment. Copy to backend/.env or set in the systemd unit.
DATABASE_URL=postgresql://factory:CHANGEME@localhost:5432/manufacturing
CORS_ORIGINS=https://factory.scottcampbell.io,http://localhost:3000

# Frontend (Next.js): set in frontend/.env.local
# Leave empty for same-origin deployment (nginx proxies /api to the backend).
NEXT_PUBLIC_API_BASE=
